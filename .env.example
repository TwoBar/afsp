# AFSP — required environment variables
# Copy to .env and edit before running

# Operator token — required, protects all control plane write endpoints
AFSP_OPERATOR_TOKEN=change-me-to-a-strong-random-token

# Database
AFSP_DB_PATH=/var/afsp/db/afsp.db

# Paths
AFSP_AGENTS_PATH=/var/afsp/agents
AFSP_VOLUMES_PATH=/var/afsp/volumes
AFSP_LOGS_PATH=/var/afsp/logs
AFSP_CACHE_PATH=/var/afsp/cache

# TTLs (seconds)
AFSP_SESSION_TTL=3600
AFSP_CACHE_TTL=300

# Runtime API URL (used by CLI)
AFSP_RUNTIME_URL=http://localhost:8000
